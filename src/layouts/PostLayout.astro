---
const { frontmatter } = Astro.props;

const postsGlob = import.meta.glob('../pages/posts/*.md', { eager: true });
const allPosts = Object.values(postsGlob).map((post: any) => ({
  url: post.url,
  frontmatter: post.frontmatter
}));

const sortedPosts = allPosts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
const recentPosts = sortedPosts.slice(0, 3);

const categoriesCount = {
  Urbex: allPosts.filter(p => p.frontmatter.category === 'Urbex').length,
  Leyendas: allPosts.filter(p => p.frontmatter.category === 'Leyendas').length,
  Folklore: allPosts.filter(p => p.frontmatter.category === 'Folklore').length,
  Videojuegos: allPosts.filter(p => p.frontmatter.category === 'Videojuegos').length,
  x: allPosts.filter(p => p.frontmatter.category === '/x/').length,
  Media: allPosts.filter(p => p.frontmatter.category === 'Media').length,
};

// Agrupar posts por Mes y Año para el Archivo (con tipos corregidos)
const archiveGroups = allPosts.reduce((groups: Record<string, number>, post: any) => {
  const dateObj = new Date(post.frontmatter.date);
  // Formateamos la fecha para obtener "Mes Año" (ej: "junio de 2026")
  const monthYear = dateObj.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });
  // Capitalizamos la primera letra
  const formattedLabel = monthYear.charAt(0).toUpperCase() + monthYear.slice(1);
  
  groups[formattedLabel] = (groups[formattedLabel] || 0) + 1;
  return groups;
}, {});
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{frontmatter.title} — Zona Muerta</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Share+Tech+Mono&family=Oswald:wght@300;400;600;700&family=Special+Elite&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="/css/style.css">
  
  <style is:inline>
    .art-hero { padding: 3.5rem 0 2rem; border-bottom: 1px solid var(--border); }
    .art-hero .breadcrumb { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text3); letter-spacing: 0.1em; margin-bottom: 1.5rem; }
    .art-hero .breadcrumb a { color: var(--text2); }
    .art-hero .breadcrumb a:hover { color: var(--text); }
    .art-hero h1 { font-family: var(--font-disp); font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 600; line-height: 1.1; letter-spacing: 0.03em; margin-bottom: 1.25rem; max-width: 720px; }
    .art-hero .art-meta { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text3); letter-spacing: 0.06em; display: flex; gap: 1rem; flex-wrap: wrap; }
    .art-cover { width: 100%; aspect-ratio: 16/7; margin: 2.5rem 0; }
    .art-cover .img-urbex { width: 100%; height: 100%; }
    .art-body { max-width: 680px; padding: 0 0 5rem; }
    .art-body p { font-size: 1rem; line-height: 1.9; color: var(--text2); margin-bottom: 1.4rem; }
    .art-body h2 { font-family: var(--font-disp); font-size: 1.35rem; font-weight: 400; letter-spacing: 0.06em; color: var(--text); margin: 2.5rem 0 1rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
    .art-body h3 { font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.15em; color: var(--red); text-transform: uppercase; margin: 2rem 0 0.75rem; }
    blockquote { border-left: 2px solid var(--red); padding: 0.75rem 1.5rem; margin: 2rem 0; }
    blockquote p { font-family: var(--font-spec); font-style: italic; font-size: 1.05rem; color: var(--text); margin: 0; }
    .exp-box { background: var(--bg3); border: 1px solid var(--border2); border-left: 2px solid var(--red-dim); padding: 1.25rem 1.5rem; margin: 2rem 0; }
    .exp-box-label { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.15em; color: var(--text3); text-transform: uppercase; margin-bottom: 0.5rem; }
    .exp-box p { font-size: 0.85rem; margin: 0; color: var(--text2); }
    .redacted { background: var(--text); color: transparent; user-select: none; padding: 0 2px; }
    .art-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); }
    .tag { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.1em; padding: 3px 8px; border: 1px solid var(--border2); color: var(--text2); text-transform: uppercase; transition: color 0.15s, border-color 0.15s; }
    .tag:hover { color: var(--red); border-color: var(--red-dim); }
    .art-layout { display: grid; grid-template-columns: 1fr 260px; gap: 4rem; }
    @media (max-width: 800px) { .art-layout { grid-template-columns: 1fr; } .sidebar { display: none; } }
    .sidebar .sidebar-block { margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
    .sidebar .sidebar-title { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.18em; color: var(--text3); text-transform: uppercase; margin-bottom: 1rem; }
  </style>
</head>
<body>

  <header>
    <div class="header-inner">
      <a href="/" class="logo-block">
        <span class="logo-sym">⊗</span>
        <span class="logo-name">ZONA MUERTA</span>
      </a>
      <nav>
        <a href="#" class="nav-link active">{frontmatter.category}</a>
        <a href="#" class="nav-link">Leyendas</a>
        <a href="#" class="nav-link">Folklore</a>
        <a href="#" class="nav-link">Videojuegos</a>
        <a href="#" class="nav-link">/x/</a>
        <a href="#" class="nav-link">Media</a>
      </nav>
    </div>
  </header>

  <main style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">

    <div class="art-hero">
      <div class="breadcrumb"><a href="/">Inicio</a> → <a href="#">{frontmatter.category}</a> → Expediente</div>
      <div class={`post-cat ${frontmatter.catClass}`} style="margin-bottom:1rem;">{frontmatter.category}</div>
      <h1>{frontmatter.title}</h1>
      <div class="art-meta">
        <span>{frontmatter.date}</span>
        <span>·</span>
        <span>{frontmatter.duration} lectura</span>
        <span>·</span>
        <span>N38°31'16" W1°46'09"</span>
      </div>
    </div>

    <div class="art-cover">
      <div class={frontmatter.imgClass}></div>
    </div>

    <div class="art-layout">
      <div class="art-body">
        
        <!-- AQUÍ SE INYECTARÁ EL TEXTO ESCRITO EN EL MARKDOWN -->
        <slot />

        <div class="art-tags">
          <a href="#" class="tag">{frontmatter.category}</a>
          <a href="#" class="tag">Albacete</a>
          <a href="#" class="tag">Psiquiátrico</a>
          <a href="#" class="tag">Edificio abandonado</a>
        </div>
      </div>

      <!-- SIDEBAR REAL ACTUALIZADA -->
      <aside class="sidebar" style="padding-top:0.5rem;">

        <div class="sidebar-block">
          <div class="sidebar-title">SOBRE ZONA MUERTA</div>
          <p class="sidebar-text">Documentamos lo inexplicable: urbex, leyendas, folklore, hilos de /x/ y todo lo que la realidad oficial prefiere ignorar. Sin clickbait. Sin exageraciones.</p>
        </div>

        <div class="sidebar-block">
          <div class="sidebar-title">Categorías</div>
          <div class="nav-categories" style="display: flex; flex-direction: column; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.75rem;">
            <p style="color: var(--text2)">Urban Exploration: <span style="color: var(--red)">{categoriesCount.Urbex}</span></p>
            <p style="color: var(--text2)">Leyendas Urbanas: <span style="color: var(--red)">{categoriesCount.Leyendas}</span></p>
            <p style="color: var(--text2)">Folklore: <span style="color: var(--red)">{categoriesCount.Folklore}</span></p>
            <p style="color: var(--text2)">Videojuegos: <span style="color: var(--red)">{categoriesCount.Videojuegos}</span></p>
            <p style="color: var(--text2)">Hilos /x/: <span style="color: var(--red)">{categoriesCount.x}</span></p>
            <p style="color: var(--text2)">Vídeos y Libros: <span style="color: var(--red)">{categoriesCount.Media}</span></p>
          </div>
        </div>

        <div class="sidebar-block">
          <div class="sidebar-title">ENTRADAS RECIENTES</div>
          <div class="recent-list">
            {recentPosts.map((post) => (
              <a href={post.url} class="recent-item">
                <div class={`recent-thumb ${post.frontmatter.imgClass}`}></div>
                <div class="recent-text">
                  <div class="recent-title">{post.frontmatter.title}</div>
                  <div class="recent-date">{post.frontmatter.date}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="sidebar-block sidebar-newsletter">
          <div class="sidebar-title">TRANSMISIONES</div>
          <p class="sidebar-text">Artículos nuevos directo a tu correo. Sin spam.</p>
          <form class="sub-form">
            <input type="email" placeholder="tu@email.com" class="sub-input" required>
            <button type="submit" class="sub-btn">Suscribirse</button>
          </form>
        </div>

        <div class="sidebar-block">
          <div class="sidebar-title">ARCHIVO</div>
          <ul class="archive-list">
            {Object.entries(archiveGroups).map(([monthYear, count]) => (
              <li>
                <a href="#">
                  {monthYear} <span style="color: var(--red)">{count}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

      </aside>
    </div>

  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-left">
        <span class="logo-sym">⊗</span>
        <span class="logo-name">ZONA MUERTA</span>
      </div>
      <nav class="footer-nav">
        <a href="/">Inicio</a><a href="#">Urbex</a><a href="#">Leyendas</a>
      </nav>
      <div class="footer-copy">© 2026 Zona Muerta</div>
    </div>
  </footer>

  <script is:inline>
    console.log('%c⊗ ZONA MUERTA','color:#c0392b;font-size:18px;font-family:monospace;font-weight:bold');
  </script>
</body>
</html>