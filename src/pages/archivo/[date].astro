---
import PostLayout from '../../layouts/PostLayout.astro';
// IMPORTANTE: Importamos el componente de optimización de imágenes de Astro
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const postsGlob = import.meta.glob('../posts/*.md', { eager: true });
  const allPosts = Object.values(postsGlob).map((post: any) => ({
    url: post.url,
    frontmatter: post.frontmatter
  }));

  const archiveSlugs = new Set(
    allPosts.map((post: any) => {
      const d = new globalThis.Date(post.frontmatter.date);
      const m = d.toLocaleDateString('es-ES', { month: 'long' });
      const y = d.toLocaleDateString('es-ES', { year: 'numeric' });
      return `${m}-${y}`.toLowerCase().replace(/\s+/g, '-');
    })
  );

  return Array.from(archiveSlugs).map((dateSlug) => {
    const filteredPosts = allPosts.filter((post: any) => {
      const d = new globalThis.Date(post.frontmatter.date);
      const m = d.toLocaleDateString('es-ES', { month: 'long' });
      const y = d.toLocaleDateString('es-ES', { year: 'numeric' });
      const currentSlug = `${m}-${y}`.toLowerCase().replace(/\s+/g, '-');
      return currentSlug === dateSlug;
    });

    const sampleDate = new globalThis.Date(filteredPosts[0].frontmatter.date);
    const rawLabel = sampleDate.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });
    const archiveLabel = rawLabel.charAt(0).toUpperCase() + rawLabel.slice(1);

    return {
      params: { date: dateSlug },
      props: { archiveLabel, posts: filteredPosts },
    };
  });
}

interface Props {
  archiveLabel: string;
  posts: any[];
}

const { archiveLabel, posts } = Astro.props;
---

<PostLayout title={`Archivo: ${archiveLabel}`}>
  <div class="archive-list-page">
    
    <div class="archive-header" style="margin-bottom: 2rem;">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--red); margin: 0;">REGISTROS DEL SISTEMA</p>
      <h2 class="archive-main-title" style="font-family: var(--font-disp); font-size: 1.5rem; margin-top: 0.5rem; border: none; padding: 0;">
        Expedientes clasificados en {archiveLabel}
      </h2>
      <p style="font-size: 0.85rem; color: var(--text2); margin-top: 0.25rem;">
        Se han recuperado {posts.length} documentos de la base de datos.
      </p>
    </div>

    <section class="posts-column">
      {posts.map((post) => (
        <>
          <article class="post-row">
            <div class="post-row-text">
              <div class={`post-cat ${post.frontmatter.catClass}`}>{post.frontmatter.category}</div>
              <h2 class="post-row-title"><a href={post.url}>{post.frontmatter.title}</a></h2>
              <p class="post-row-excerpt">{post.frontmatter.excerpt}</p>
              <div class="post-meta">
                <span>{post.frontmatter.date}</span>
                <span class="sep">·</span>
                <span>{post.frontmatter.duration}</span>
              </div>
            </div>
            <div class={`post-row-thumb ${post.frontmatter.imgClass || ''}`}>
              {post.frontmatter.thumbImg ? (
                /* REEMPLAZADO POR EL COMPONENTE OPTIMIZADO */
                <Image 
                  src={post.frontmatter.thumbImg} 
                  alt={post.frontmatter.title} 
                  width={200}
                  height={150}
                  loading="lazy"
                  style="width:100%; height:100%; object-fit:cover;" 
                />
              ) : null}
            </div>
          </article>
          <div class="post-divider"></div>
        </>
      ))}
    </section>
  </div>
</PostLayout>

<style>
  /* Por defecto en Escritorio es Flex horizontal */
  .archive-list-page .post-row {
    display: flex !important;
    align-items: flex-start !important;
  }
  
  .archive-list-page .post-row-title {
    border: none !important;
    padding: 0 !important;
    margin-top: 0.25rem !important;
    margin-bottom: 0.5rem !important;
    font-size: 1.25rem !important;
  }

  .archive-list-page .post-row-title a {
    text-decoration: none !important;
    border: none !important;
  }

  .archive-list-page .post-row-thumb {
    flex-shrink: 0 !important;
  }


  @media (max-width: 768px) {
    .archive-list-page .post-row {
      display: flex !important;
      flex-direction: column-reverse !important;
      gap: 15px !important;
    }
  }
</style>