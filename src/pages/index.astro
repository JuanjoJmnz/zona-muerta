---
// 1. Usamos la nueva herramienta nativa de Vite que pide Astro v6 para leer archivos
const postsGlob = import.meta.glob('./posts/*.md', { eager: true });

// 2. Transformamos esos archivos en una lista que JS pueda entender
const allPosts = Object.values(postsGlob).map((post: any) => ({
  url: post.url,
  frontmatter: post.frontmatter
}));

// 3. Los ordenamos por fecha (el más reciente primero)
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime();
});

// 4. Separamos el destacado del resto, igual que antes
const featuredPost = sortedPosts[0];
const regularPosts = sortedPosts.slice(1);
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ZONA MUERTA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Share+Tech+Mono&family=Oswald:wght@300;400;600;700&family=Special+Elite&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- ============ INTRO ESTÁTICA (The Ring) ============ -->
  <div id="static-intro">
    <canvas id="static-canvas"></canvas>
    <div class="static-content">
      <div class="static-symbol">⊗</div>
      <div class="static-title">ZONA MUERTA</div>
      <div class="static-sub">CARGANDO ARCHIVO...</div>
    </div>
    <div class="static-skip" onclick="skipIntro()">saltar →</div>
  </div>

  <!-- ============ PÁGINA PRINCIPAL ============ -->
  <div id="main-site" class="hidden">

    <header>
      <div class="header-inner">
        <a href="index.html" class="logo-block">
          <span class="logo-sym">⊗</span>
          <span class="logo-name">ZONA MUERTA</span>
        </a>
        <nav>
          <a href="#" class="nav-link active">Inicio</a>
          <a href="pages/categoria.html" class="nav-link">Urbex</a>
          <a href="pages/categoria.html" class="nav-link">Leyendas</a>
          <a href="pages/categoria.html" class="nav-link">Folklore</a>
          <a href="pages/categoria.html" class="nav-link">Videojuegos</a>
          <a href="pages/categoria.html" class="nav-link">/x/</a>
          <a href="pages/categoria.html" class="nav-link">Media</a>
        </nav>
        <div class="header-right">
          <button class="search-btn" onclick="toggleSearch()"><span>&#9906;</span></button>
        </div>
      </div>
      <div id="search-bar" class="search-bar hidden">
        <input type="text" placeholder="buscar en el archivo..." class="search-input" autofocus>
      </div>
    </header>

    <main>

      <!-- POST DESTACADO -->
      {featuredPost && (
        <section class="featured-post">
          <div class="featured-inner">
            <div class="featured-text">
              <div class={`post-cat ${featuredPost.frontmatter.catClass}`}>{featuredPost.frontmatter.category}</div>
              <h1 class="featured-title">
                <a href={featuredPost.url}>{featuredPost.frontmatter.title}</a>
              </h1>
              <p class="featured-excerpt">{featuredPost.frontmatter.excerpt}</p>
              <div class="post-meta">
                <span>{featuredPost.frontmatter.date}</span>
                <span class="sep">·</span>
                <span>{featuredPost.frontmatter.duration}</span>
              </div>
            </div>
            <div class="featured-img-wrap">
              <div class={`featured-img ${featuredPost.frontmatter.imgClass}`}></div>
            </div>
          </div>
        </section>
      )}

      <div class="divider"></div>

      <!-- LAYOUT PRINCIPAL: BLOG + SIDEBAR -->
      <div class="content-layout">

        <!-- COLUMNA DE POSTS -->
      <section class="posts-column">
        {regularPosts.map((post) => (
          <>
            <article class="post-row">
              <div class="post-row-text">
                <div class={`post-cat ${post.frontmatter.catClass}`}>{post.frontmatter.category}</div>
                <h2 class="post-row-title"><a href={post.url}>{post.frontmatter.title}</a></h2>
                <p class="post-row-excerpt">{post.frontmatter.excerpt}</p>
                <div class="post-meta">
                  <span>{post.frontmatter.date}</span>
                  <span class="sep">·</span>
                  <span>{post.frontmatter.duration}</span>
                </div>
              </div>
              <div class={`post-row-thumb ${post.frontmatter.imgClass}`}></div>
            </article>
            <div class="post-divider"></div>
          </>
        ))}
      </section>

        <!-- SIDEBAR -->
        <aside class="sidebar">

          <div class="sidebar-block">
            <div class="sidebar-title">SOBRE ZONA MUERTA</div>
            <p class="sidebar-text">Documentamos lo inexplicable: urbex, leyendas, folklore, hilos de /x/ y todo lo que la realidad oficial prefiere ignorar. Sin clickbait. Sin exageraciones.</p>
          </div>

          <div class="sidebar-block">
            <div class="sidebar-title">CATEGORÍAS</div>
            <ul class="cat-list">
              <li><a href="#">Urban Exploration <span>43</span></a></li>
              <li><a href="#">Leyendas Urbanas <span>34</span></a></li>
              <li><a href="#">Folklore <span>21</span></a></li>
              <li><a href="#">Videojuegos <span>18</span></a></li>
              <li><a href="#">Hilos /x/ <span>27</span></a></li>
              <li><a href="#">Vídeos y Libros <span>19</span></a></li>
            </ul>
          </div>

          <div class="sidebar-block">
            <div class="sidebar-title">ENTRADAS RECIENTES</div>
            <div class="recent-list">
              <a href="#" class="recent-item">
                <div class="recent-thumb img-urbex"></div>
                <div class="recent-text">
                  <div class="recent-title">El Sanatorio de Agramón</div>
                  <div class="recent-date">14 jun 2025</div>
                </div>
              </a>
              <a href="#" class="recent-item">
                <div class="recent-thumb img-xchan"></div>
                <div class="recent-text">
                  <div class="recent-title">La puerta que no existía</div>
                  <div class="recent-date">10 jun 2025</div>
                </div>
              </a>
              <a href="#" class="recent-item">
                <div class="recent-thumb img-leyenda"></div>
                <div class="recent-text">
                  <div class="recent-title">La Chica del Túnel de Vallecas</div>
                  <div class="recent-date">7 jun 2025</div>
                </div>
              </a>
            </div>
          </div>

          <div class="sidebar-block sidebar-newsletter">
            <div class="sidebar-title">TRANSMISIONES</div>
            <p class="sidebar-text">Artículos nuevos directo a tu correo. Sin spam.</p>
            <form onsubmit="handleSub(event)" class="sub-form">
              <input type="email" placeholder="tu@email.com" class="sub-input" required>
              <button type="submit" class="sub-btn">Suscribirse</button>
            </form>
          </div>

          <div class="sidebar-block">
            <div class="sidebar-title">ARCHIVO</div>
            <ul class="archive-list">
              <li><a href="#">Junio 2025 <span>6</span></a></li>
              <li><a href="#">Mayo 2025 <span>11</span></a></li>
              <li><a href="#">Abril 2025 <span>9</span></a></li>
              <li><a href="#">Marzo 2025 <span>13</span></a></li>
              <li><a href="#">Febrero 2025 <span>8</span></a></li>
            </ul>
          </div>

        </aside>

      </div>
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-left">
          <span class="logo-sym">⊗</span>
          <span class="logo-name">ZONA MUERTA</span>
        </div>
        <nav class="footer-nav">
          <a href="#">Inicio</a>
          <a href="#">Urbex</a>
          <a href="#">Leyendas</a>
          <a href="#">Folklore</a>
          <a href="#">Videojuegos</a>
          <a href="#">/x/</a>
          <a href="#">Media</a>
          <a href="#">Contacto</a>
        </nav>
        <div class="footer-copy">© 2025 Zona Muerta</div>
      </div>
    </footer>

  </div><!-- /#main-site -->

  <script is:inline src="/js/main.js"></script>
</body>
</html>
