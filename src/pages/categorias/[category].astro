---
import PostLayout from '../../layouts/PostLayout.astro';

interface PostFrontmatter {
  title: string;
  date: string;
  duration: string;
  category: string;
  catClass?: string;
  imgClass?: string;
  excerpt: string;
  layout?: string;
}

interface MarkdownPost {
  url: string;
  frontmatter: PostFrontmatter;
}

// Diccionario clonado para emparejar descripciones automáticamente en base al parámetro de la URL
const categoriesInfo: Record<string, { name: string, desc: string }> = {
  'urbex': { name: 'Urbex', desc: 'Exploraciones urbanas que desafían el olvido y desentierran secretos ocultos en el hormigón abandonado.' },
  'leyendas': { name: 'Leyendas Urbanas', desc: 'Mitos contemporáneos y relatos de terror nacidos en el asfalto de todas las ciudades.' },
  'folklore': { name: 'Folklore', desc: 'Folklore tradicional recopilado de antiguos mitos, leyendas rurales e historias olvidadas del campo.' },
  'videojuegos': { name: 'Videojuegos', desc: 'Videojuegos malditos, creepypastas interactivos y títulos de terror que te hacen dudar de tu propia pantalla.' },
  '-x-': { name: '/x/', desc: 'Los hilos de /x/ más terroríficos y misteriosos extraídos directamente del tablón paranormal de internet.' },
  'media': { name: 'Media', desc: 'Libros, vídeos o películas que profundizan en los rincones más oscuros e inexplicables de nuestra realidad.' }
};

export async function getStaticPaths() {
  const postFiles = import.meta.glob<MarkdownPost>('../posts/*.md', { eager: true });
  const allPosts: MarkdownPost[] = Object.values(postFiles);
  
  const uniqueCategories: string[] = [
    ...new Set(allPosts.map((post) => post.frontmatter.category).filter(Boolean))
  ];

  return uniqueCategories.map((category: string) => {
    let urlParam = category.toLowerCase().replace(/\s+/g, '-');
    if (urlParam === 'x' || urlParam === '/x/') {
      urlParam = '-x-';
    }
    
    const filteredPosts = allPosts.filter((post) => post.frontmatter.category === category);
    
    return {
      params: { category: urlParam },
      props: { categoryName: category, categorySlug: urlParam, posts: filteredPosts },
    };
  });
}

interface Props {
  categoryName: string;
  categorySlug: string;
  posts: MarkdownPost[];
}

const { categoryName, posts } = Astro.props as Props;

// EVITAR EL ERROR DEL PROBLEMA 4:
// Si la categoría nos llega como 'x' o '-x-', la renombramos limpiamente a '/x/'
const finalCategoryTitle = (categoryName === 'x' || categoryName === '-x-') ? '/x/' : categoryName;
---

<PostLayout title={`Categoría: ${finalCategoryTitle}`}>
  <main class="category-page">
    
    <div class="breadcrumb" style="margin-bottom: 2rem; font-family: monospace; font-size: 0.8rem; color: #7f8c8d;">
      <a href="/" style="color: #c0392b; text-decoration: none;">Inicio</a> → 
      <a href="/categorias" style="color: #c0392b; text-decoration: none;">Categorías</a> → 
      <span style="color: #fff;">{finalCategoryTitle}</span>
    </div>

    <h1 class="page-title">Transmisiones en: <span class="highlight">{finalCategoryTitle}</span></h1>
    <p class="page-subtitle">Se han encontrado {posts.length} archivos clasificados en la base de datos.</p>

    <div class="posts-grid">
      {posts.map((post) => (
        <article class="post-card">
          <div class={`card-header ${post.frontmatter.catClass || ''}`}>
            <span class="category-badge">
              {(post.frontmatter.category === 'x' || post.frontmatter.category === '-x-') ? '/x/' : post.frontmatter.category}
            </span>
            <span class="post-duration">// Lectura: {post.frontmatter.duration}</span>
          </div>
          
          <h2><a href={post.url}>{post.frontmatter.title}</a></h2>
          <p class="post-date">Fecha de registro: {post.frontmatter.date}</p>
          <p class="post-excerpt">{post.frontmatter.excerpt}</p>
          <a href={post.url} class="read-more">Abrir expediente →</a>
        </article>
      ))}
    </div>
  </main>
</PostLayout>